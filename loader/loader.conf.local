# Unicode support
libiconv_load="YES"
libmchain_load="YES"
msdosfs_iconv_load="YES" 

# Audio - EQ Enable
snd_uaudio_load="YES"
hint.pcm.0.eq=1
hint.pcm.1.eq=1
hint.pcm.2.eq=1

# HTCP TCP Congestion Control
#cc_htcp_load="YES"

# TCP BBR
tcp_bbr_load="YES"

# CPU
cpu_microcode_load="YES"
cpu_microcode_name="/boot/firmware/intel-ucode.bin"
