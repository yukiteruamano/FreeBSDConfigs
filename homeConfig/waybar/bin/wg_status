#!/usr/bin/env bash

# Comprobamos si la ruta de la mitad inferior de internet apunta a wg0
# 'netstat -rn' es accesible por cualquier usuario y es la fuente de verdad del kernel
CHECK_VPN=$(netstat -rn | awk '$1 == "0.0.0.0/1" && $4 == "wg0" {print $1}')

if [ -n "$CHECK_VPN" ]; then
    # Salida JSON cuando el tráfico está bunkerizado
    echo "{\"text\": \"VPN\", \"class\": \"connected\"}"
else
    # Salida JSON en navegación directa (Modo claro)
    echo "{\"text\": \"NO VPN\", \"class\": \"disconnected\"}"
fi
