#!/usr/bin/env bash

# 1. Obtenemos el valor (ej: 49,0C o 49.0C)
RAW=$(sysctl -n dev.cpu.0.temperature)

# 2. Normalizamos: cambiamos coma por punto y quitamos la C
# Esto convierte "49,0C" en "49.0"
TEMP_NORM=$(echo "$RAW" | tr ',' '.' | sed 's/C//')

# 3. Obtenemos el entero para las comparaciones (49.0 -> 49)
TEMP_INT=$(echo "$TEMP_NORM" | cut -d. -f1)

# 4. Lógica de alertas (usando el entero, que no falla en [ ])
if [ "$TEMP_INT" -gt 75 ]; then
    CLASS="critical"
elif [ "$TEMP_INT" -gt 55 ]; then
    CLASS="warning"
else
    CLASS="normal"
fi

# 5. Salida JSON limpia
# IMPORTANTE: En el "value" enviamos el entero para evitar errores de parseo
echo "{\"text\": \"$TEMP_INT\", \"value\": $TEMP_INT, \"class\": \"$CLASS\"}"